{
  "name": "llama-cpp-launcher",
  "private": true,
  "version": "1.0.5",
  "type": "module",
  "scripts": {
    "dev:web": "vite",
    "build:web": "node ./node_modules/typescript/bin/tsc && node ./node_modules/vite/bin/vite.js build",
    "dev": "tauri dev",
    "build": "tauri build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:types": "cargo test --manifest-path src-tauri/Cargo.toml export_typescript_bindings -- --nocapture"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.3.3"
  }
}
