{
  "productName": "LLama C++ Launcher",
  "version": "1.0.1",
  "identifier": "com.llama.launcher",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "node node_modules/typescript/bin/tsc && node node_modules/vite/bin/vite.js build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LLama C++ Launcher",
        "width": 900,
        "height": 700,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": [
        "default-capability"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
